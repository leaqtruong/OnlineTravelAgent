// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PARTNER
  ADMIN
}

model Category {
  id   String @id @default(cuid())
  name String @unique

  @@map("categories")
}

model Destination {
  id            String  @id
  name          String
  location      String
  latitude      Float?
  longitude     Float?
  rating        String  @default("0.0")
  duration      String
  imagePath     String  @map("image_path")
  description   String
  price         Float
  reviewsCount  String  @default("0") @map("reviews_count")
  category      String
  isFavorite    Boolean @default(false) @map("is_favorite")
  isRecommended Boolean @default(false) @map("is_recommended")

  scheduleTemplates ScheduleTemplate[]

  @@index([category])
  @@index([isRecommended])
  @@map("destinations")
}

model Trip {
  id          String   @id
  destination String
  location    String
  date        String
  guests      String
  status      String
  imagePath   String   @map("image_path")
  isUpcoming  Boolean  @default(true) @map("is_upcoming")
  
  flightId    String?  @map("flight_id")
  hotelId     String?  @map("hotel_id")
  roomId      String?  @map("room_id")
  totalPrice  Float?   @map("total_price")
  isCustom    Boolean  @default(false) @map("is_custom")

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  promoCode   String?  @map("promo_code")
  discount    Float?   @default(0)

  paymentMethod   String?  @map("payment_method")
  paymentStatus   String?  @default("pending") @map("payment_status")
  paymentTxnRef   String?  @map("payment_txn_ref")
  paymentTxnNumber String? @map("payment_txn_number")

  createdAt   DateTime @default(now()) @map("created_at")

  scheduleDays    TripScheduleDay[]
  scheduleUpdates TripScheduleUpdate[]

  @@index([userId])
  @@index([isUpcoming])
  @@index([createdAt])
  @@map("trips")
}

model Flight {
  id            String @id
  airline       String
  airlineLogo   String @map("airline_logo")
  departure     String
  arrival       String
  departureTime String @map("departure_time")
  arrivalTime   String @map("arrival_time")
  price         Float
  duration      String

  @@map("flights")
}

model DocumentItem {
  id          String @id
  title       String
  description String
  icon        String
  color       String

  createdAt DateTime @default(now()) @map("created_at")

  @@map("document_items")
}

model Hotel {
  id          String  @id
  name        String
  location    String
  latitude    Float?
  longitude   Float?
  rating      String  @default("0.0")
  imagePath   String  @map("image_path")
  description String
  priceFrom   Float   @map("price_from")
  address     String
  amenities   String[]
  
  partnerId   String? @map("partner_id")
  partner     User?   @relation("PartnerHotels", fields: [partnerId], references: [id])

  rooms       Room[]
  
  @@index([location])
  @@index([partnerId])
  @@map("hotels")
}

model Room {
  id          String @id
  hotelId     String @map("hotel_id")
  name        String
  description String
  price       Float
  capacity    Int
  imagePath   String @map("image_path")
  amenities   String[]
  
  hotel       Hotel  @relation(fields: [hotelId], references: [id])
  
  @@index([hotelId])
  @@map("rooms")
}

model TourPackage {
  id            String   @id
  name          String
  description   String
  imagePath     String   @map("image_path")
  duration      String
  price         Float
  originalPrice Float?   @map("original_price")
  destinations  String[]
  includes      String[]
  departure     String
  departureDate String?  @map("departure_date")
  isPopular     Boolean  @default(false) @map("is_popular")
  includesGuide Boolean  @default(true) @map("includes_guide")
  guideFee      Float    @default(50.0) @map("guide_fee")
  
  partnerId     String?  @map("partner_id")
  partner       User?    @relation("PartnerTours", fields: [partnerId], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")

  scheduleTemplates ScheduleTemplate[]
  
  @@index([createdAt])
  @@index([partnerId])
  @@map("tour_packages")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")

  trips     Trip[]
  reviews   Review[]
  hotels    Hotel[]       @relation("PartnerHotels")
  tours     TourPackage[] @relation("PartnerTours")

  @@map("users")
}

model Review {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  rating     Int
  comment    String
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([targetType, targetId])
  @@index([userId])
  @@map("reviews")
}

model ScheduleTemplate {
  id            String   @id @default(cuid())
  name          String
  sourceType    String   @map("source_type")
  tourPackageId String?  @map("tour_package_id")
  destinationId String?  @map("destination_id")

  tourPackage TourPackage? @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  days        ScheduleTemplateDay[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sourceType])
  @@index([tourPackageId])
  @@index([destinationId])
  @@map("schedule_templates")
}

model ScheduleTemplateDay {
  id         String @id @default(cuid())
  templateId String @map("template_id")
  dayNumber  Int    @map("day_number")
  title      String?

  template ScheduleTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    ScheduleTemplateItem[]

  @@unique([templateId, dayNumber])
  @@index([templateId])
  @@index([dayNumber])
  @@map("schedule_template_days")
}

model ScheduleTemplateItem {
  id           String  @id @default(cuid())
  dayId        String  @map("day_id")
  startTime    String  @map("start_time")
  endTime      String? @map("end_time")
  title        String
  description  String?
  locationName String? @map("location_name")
  latitude     Float?
  longitude    Float?
  sortOrder    Int     @default(0) @map("sort_order")

  day ScheduleTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([sortOrder])
  @@map("schedule_template_items")
}

model TripScheduleDay {
  id        String    @id @default(cuid())
  tripId    String    @map("trip_id")
  dayNumber Int       @map("day_number")
  date      DateTime?
  title     String?

  trip  Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items TripScheduleItem[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
  @@index([dayNumber])
  @@map("trip_schedule_days")
}

model TripScheduleItem {
  id             String   @id @default(cuid())
  dayId          String   @map("day_id")
  startTime      String   @map("start_time")
  endTime        String?  @map("end_time")
  title          String
  description    String?
  locationName   String?  @map("location_name")
  latitude       Float?
  longitude      Float?
  sortOrder      Int      @default(0) @map("sort_order")
  statusOverride String?  @map("status_override")
  note           String?
  updatedAt      DateTime @updatedAt @map("updated_at")

  day TripScheduleDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([sortOrder])
  @@map("trip_schedule_items")
}

model TripScheduleUpdate {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([createdAt])
  @@map("trip_schedule_updates")
}

model PromoCode {
  id                 String    @id @default(cuid())
  code               String    @unique
  discountPercentage Float?    @map("discount_percentage")
  discountAmount     Float?    @map("discount_amount")
  maxUses            Int       @default(100) @map("max_uses")
  currentUses        Int       @default(0) @map("current_uses")
  validUntil         DateTime? @map("valid_until")
  isActive           Boolean   @default(true) @map("is_active")

  @@map("promo_codes")
}
