# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/online_travel_agent?schema=public"

# Server port
PORT=3000

# JWT secret for token signing (REQUIRED - app will not start without it)
JWT_SECRET="your-super-secret-jwt-key-here"

# Admin password for admin panel Basic Auth (REQUIRED for admin access)
ADMIN_PASSWORD="your-admin-password-here"

# CORS allowed origins (comma-separated)
# CORS_ORIGINS="http://localhost:3000,http://10.0.2.2:3000"
