# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/online_travel_agent?schema=public"

# Server port
PORT=3000

# JWT secret for token signing (REQUIRED - app will not start without it)
JWT_SECRET="your-super-secret-jwt-key-here"

# Admin password for admin panel Basic Auth (REQUIRED for admin access)
ADMIN_PASSWORD="your-admin-password-here"

# CORS allowed origins (comma-separated). Required when NODE_ENV=production.
CORS_ORIGINS="http://localhost:3000,http://10.0.2.2:3000"

# Reverse proxy trust setting for deployments behind Nginx/Render/Fly/Cloudflare/etc.
# Use 1 when exactly one trusted proxy sits in front of Express.
TRUST_PROXY="false"

# Optional upload directory. Defaults to backend/public/uploads locally.
# UPLOAD_DIR="/app/public/uploads"
